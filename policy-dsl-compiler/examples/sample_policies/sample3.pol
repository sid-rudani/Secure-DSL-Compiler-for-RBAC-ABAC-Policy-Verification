// Sample Policy 3: Cloud Infrastructure Access
policy cloud_infra {
    allow action: read resource: instances role: developer;
    allow action: write resource: instances role: devops;
    allow action: delete resource: instances role: admin;
    allow action: read resource: logs role: developer;
    allow action: write resource: logs role: admin;
    allow action: execute resource: scripts role: devops;
    deny action: delete resource: database role: developer;
}
