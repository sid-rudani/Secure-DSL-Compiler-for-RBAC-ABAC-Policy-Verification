policy role_hierarchy_example {
    user user1;
    user user2;
    
    role admin;
    role supervisor < admin;
    role employee < supervisor;
    
    resource document;
    resource report;
    
    action read;
    action write;
    action approve;
    
    rule admin_write_document {
        effect: allow
        subject: role admin
        action: write
        resource: document
    }
    
    rule admin_approve_report {
        effect: allow
        subject: role admin
        action: approve
        resource: report
    }
    
    rule supervisor_read_document {
        effect: allow
        subject: role supervisor
        action: read
        resource: document
    }
    
    rule employee_read_only {
        effect: allow
        subject: role employee
        action: read
        resource: document
    }
    
    rule employee_cannot_write {
        effect: deny
        subject: role employee
        action: write
        resource: report
    }
}
